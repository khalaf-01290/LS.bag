# LS.bag Environment Variables Template
# Copy this file to .env and fill in your keys

# GitHub
GITHUB_PAT=your_github_pat_here

# AI APIs
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
